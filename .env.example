# GroundTruth Financial Planning Platform — Environment Variables
# Copy to .env and fill in production values.

# --- Core ---
GROUNDTRUTH_ENV=development              # development | production
GROUNDTRUTH_DEV_MODE=1                   # 1 = dev key accepted, 0 = require real API keys

# --- Database ---
DATABASE_URL=sqlite:///outputs/groundtruth.db   # PostgreSQL: postgresql://user:pass@localhost:5432/groundtruth

# --- API Authentication ---
GROUNDTRUTH_API_KEY=dev-key-change-me    # MUST change in production (triggers startup error if default)

# --- Encryption ---
# Required for profile encryption at rest and Open Banking token storage.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# GROUNDTRUTH_TOKEN_KEY=

# --- CORS ---
GROUNDTRUTH_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
GROUNDTRUTH_RATE_LIMIT_RPM=60            # Requests per minute per API key

# --- Clerk Authentication (v9.3+) ---
CLERK_SECRET_KEY=                          # sk_test_... (dev) or sk_live_... (prod) — from Clerk dashboard
CLERK_PUBLISHABLE_KEY=                     # pk_test_... or pk_live_... — backend needs this to derive the Clerk Frontend API domain for JWKS verification. Same value as VITE_CLERK_PUBLISHABLE_KEY below.
# Frontend reads its copy from web/.env.local:
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Open Banking (TrueLayer) ---
# TRUELAYER_CLIENT_ID=
# TRUELAYER_CLIENT_SECRET=
# TRUELAYER_REDIRECT_URI=http://localhost:8000/api/v1/banking/callback
# TRUELAYER_SANDBOX=1                    # 1 = sandbox, 0 = production
